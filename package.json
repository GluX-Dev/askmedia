{
  "name": "ask-media-storefront",
  "version": "1.0.0",
  "description": "Standalone Firebase Storefront Platform",
  "main": "functions/src/server.js",
  "engines": {
    "node": "^18.0.0 || ^20.0.0"
  },
  "scripts": {
    "start": "node functions/src/server.js",
    "dev": "node functions/src/server.js",
    "firebase:doctor": "node scripts/firebase-credential-doctor.js",
    "deploy": "firebase deploy --only hosting,functions,database",
    "deploy:full": "firebase deploy --only hosting,functions,database",
    "deploy:function:app": "firebase deploy --only functions:app",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:hosting:askmedia": "firebase deploy --only hosting:askmedia",
    "deploy:rules": "firebase deploy --only database:rules"
  },
  "keywords": [
    "firebase",
    "storefront",
    "paystack",
    "ecommerce"
  ],
  "author": "ASK MEDIA",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0"
  }
}
